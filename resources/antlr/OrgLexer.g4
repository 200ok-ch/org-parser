lexer grammar OrgLexer;

NEWLINE: '\r'? '\n';
STAR: '*';
LBRACK: '[';
RBRACK: ']';
HASH: '#';
END_DRAWER: ':END:';
COLON: ':';
DASH: '-';
PLUS: '+';
BAR: '|';
UNDERSCORE: '_';
LT: '<';
GT: '>';
LPAREN: '(';
RPAREN: ')';
LBRACE: '{';
RBRACE: '}';
BACKSLASH: '\\';
SLASH: '/';
EQUALS: '=';
TILDE: '~';
DOT: '.';
COMMA: ',';
PERCENT: '%';
AT: '@';
QUESTION: '?';
EXCL: '!';
SPACE: [ \t];
COMMENT: 'COMMENT';
UPPER: [A-Z];
LOWER: [a-z];
DIGIT: [0-9];
TEXT_CHAR: ~[\r\n];
